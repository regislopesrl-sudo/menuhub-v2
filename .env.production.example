POSTGRES_PASSWORD=troque_esta_senha
DATABASE_URL=postgresql://postgres:troque_esta_senha@postgres:5432/sistema_delivery_futuro?schema=public

JWT_ACCESS_SECRET=troque_access_secret
JWT_REFRESH_SECRET=troque_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

NEXT_PUBLIC_API_URL=https://api.menuhub.net.br/api/v1

