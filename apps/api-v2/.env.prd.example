# API V2 - PRD example
NODE_ENV=production
PORT=3202

# Database
POSTGRES_DB=menuhub_v2_prd
POSTGRES_USER=menuhub
POSTGRES_PASSWORD=menuhub_prd_change_me
DATABASE_URL=postgresql://menuhub:menuhub_prd_change_me@postgres-v2:5432/menuhub_v2_prd

# CORS
CORS_ORIGIN=https://app.menuhub.net.br,https://admin.menuhub.net.br
SOCKET_CORS_ORIGIN=https://app.menuhub.net.br,https://admin.menuhub.net.br

# Context defaults (until full auth)
DEFAULT_COMPANY_ID=company-prod
DEFAULT_BRANCH_ID=branch-prod
DEVELOPER_ACCESS_CODE=change_me_dev_code

# Payments (production)
PAYMENT_PROVIDER=mercadopago
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
MERCADO_PAGO_NOTIFICATION_URL=https://api.menuhub.net.br/v2/payments/webhook/mercadopago
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_TIMEOUT_MS=10000
